# ─────────────────────────────────────────────────────────────────────────────
# New Japan Deals — Environment Variables
# Copy this file to .env.local for local development.
# All variables prefixed NEXT_PUBLIC_ are embedded in the client bundle.
# Never set NEXT_PUBLIC_ on secrets (admin keys, DB passwords, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# ── Meilisearch (Option A — preferred) ───────────────────────────────────────
# Get these from https://cloud.meilisearch.com after creating a "products" project.
# Leave blank to fall back to PHP API search.
NEXT_PUBLIC_MEILISEARCH_HOST=
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=       # Search-only / public key (safe to expose)
MEILISEARCH_ADMIN_KEY=                    # Admin key — server-side only, never NEXT_PUBLIC_

# ── Cron / Webhook security ───────────────────────────────────────────────────
# Protect cron endpoints. Vercel sets this automatically when you add cron jobs.
CRON_SECRET=
# Protect the product-updated webhook. Set the same value in the PHP backend.
NJD_WEBHOOK_SECRET=

# ── Trust Stats — manual override (instant authentic numbers on day 1) ────────
# Resolution order: env vars > scraper cache > config/trust-stats.json fallback
NJD_MERCARI_RATING=4.9
NJD_MERCARI_REVIEW_COUNT=1247
NJD_RAKUMA_RATING=4.8
NJD_RAKUMA_REVIEW_COUNT=612
NJD_SHIPPED_2025=438
NJD_COUNTRIES_SHIPPED=32

# ── Scraper seller IDs (optional — enables live scraping) ─────────────────────
NJD_MERCARI_SELLER_ID=
NJD_RAKUMA_SELLER_ID=
