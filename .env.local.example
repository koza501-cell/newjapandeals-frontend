# ─── New Japan Deals — Environment Variables ───────────────────────────────
# Copy to .env.local for local development. Never commit .env.local.
# Add all of these in: Vercel → Project → Settings → Environment Variables

# ── Site URL (required for server-side trust-stats prefetch on homepage) ────
NEXT_PUBLIC_SITE_URL=https://www.newjapandeals.com

# ── Meilisearch (search engine) ─────────────────────────────────────────────
NEXT_PUBLIC_MEILISEARCH_HOST=https://your-instance.meilisearch.io
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your_search_only_public_key
MEILISEARCH_ADMIN_KEY=your_admin_api_key

# ── Cron protection ──────────────────────────────────────────────────────────
CRON_SECRET=generate_with_openssl_rand_hex_32

# ── Webhook security ─────────────────────────────────────────────────────────
NJD_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ── On-demand revalidation ───────────────────────────────────────────────────
# Usage: GET /api/revalidate?path=/&secret=VALUE  (see docs/revalidation.md)
REVALIDATE_SECRET=generate_with_openssl_rand_hex_32

# ── Trust statistics (manual override — highest priority) ────────────────────
# Resolution order: these env vars > scraper cache > config/trust-stats.json
NJD_MERCARI_RATING=4.9
NJD_MERCARI_REVIEW_COUNT=1247
NJD_MERCARI_URL=https://jp.mercari.com/user/profile/YOUR_SELLER_ID
NJD_RAKUMA_RATING=4.8
NJD_RAKUMA_REVIEW_COUNT=612
NJD_RAKUMA_URL=https://fril.jp/shop/YOUR_SHOP_ID
NJD_SHIPPED_2025=438
NJD_COUNTRIES_SHIPPED=32

# ── Scraper seller IDs (used by nightly cron) ────────────────────────────────
NJD_MERCARI_SELLER_ID=your_mercari_seller_id
NJD_RAKUMA_SELLER_ID=your_rakuma_seller_id
